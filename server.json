{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.terobyte/librarian",
  "title": "Librarian",
  "description": "Deterministic book-to-markdown pipeline with a built-in MCP server for browsing, searching, and reading your ebook library.",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/Terobyte/librarian-cli",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "librarian-cli",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "LIB_HOME",
          "description": "Library root directory (default ./library)",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}
